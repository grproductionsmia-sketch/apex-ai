# ============================================================
# Apex AI — env template. Copy to .env and fill in real values.
# Do NOT put real secrets here. This file IS committed.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx        # client-side (respects RLS)
SUPABASE_SECRET_KEY=sb_secret_xxx                  # server-side ONLY (bypasses RLS)

# Direct Postgres connection — REQUIRED to apply migrations (DDL).
# Supabase: Settings > Database > Connection string > URI.
SUPABASE_DB_URL=postgresql://postgres:[DB-PASSWORD]@db.YOUR-PROJECT-ref.supabase.co:5432/postgres

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6                  # standard brain for the 6 agents
ANTHROPIC_COMPLIANCE_MODEL=claude-opus-4-6         # strongest model for compliance 2nd pass

# --- Meta / WhatsApp ---
META_APP_ID=
META_APP_SECRET=
WHATSAPP_TEST_NUMBER=                              # E.164, e.g. +15551234567

# --- Queues / worker ---
REDIS_URL=redis://localhost:6379
